# Web3Forms Setup (optional)
# To enable email functionality on the contact form:
# 1. Sign up at https://web3forms.com (free, no credit card required)
# 2. Get your API key from the dashboard
# 3. Copy this file: `cp .env.example .env.local`
# 4. Add your API key to the VITE_WEB3FORMS_KEY variable
# 5. Uncomment the Web3Forms code in src/components/sections/Contact.tsx

VITE_WEB3FORMS_KEY=your_api_key_here
